# 蒲公英 API Key (必需)
# 在 https://www.pgyer.com/account/api 获取
PGYER_API_KEY=your_api_key_here

# ========== iOS 签名（Secrets 方式，仅 CI 需要） ==========
# 本地跑 fastlane 不需要填这些，会自动 fallback 到 Xcode 自动签名
# CI 必须设置 IOS_P12_BASE64 + IOS_P12_PASSWORD + 描述文件 + IOS_PROVISIONING_PROFILE_NAME

# p12 证书内容（base64 后一行）
IOS_P12_BASE64=

# 导出 p12 时设置的密码
IOS_P12_PASSWORD=

# 描述文件 mobileprovision 内容（base64 后一行）
IOS_MOBILEPROVISION_BASE64=

# 若 IOS_MOBILEPROVISION_BASE64 超过 GitHub Secret 限制，可使用
# gzip 后再 base64 的版本（二选一）
IOS_MOBILEPROVISION_BASE64_GZ=

# 描述文件名称（例如：iOS Team Provisioning Profile: *）
IOS_PROVISIONING_PROFILE_NAME=

# 签名模式（可选：manual / automatic）
# 留空会自动判断：iOS Team Provisioning Profile:* -> automatic，否则 manual
IOS_SIGNING_STYLE=

# Team ID（可选，推荐填写）
IOS_TEAM_ID=E2R9X4F3GH

# 可选：keychain 名称与密码（一般不用设置）
IOS_KEYCHAIN_NAME=
IOS_KEYCHAIN_PASSWORD=
